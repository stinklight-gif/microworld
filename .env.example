# ─── LLM Configuration ───────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint works (OpenAI, Ollama, LM Studio, Together, etc.)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# ─── Simulation Parameters ───────────────────────────────────────────────────
ROUNDS=50
TRADE_ROUNDS_PER_TURN=3
LOG_DIR=./logs
VERBOSE=true
